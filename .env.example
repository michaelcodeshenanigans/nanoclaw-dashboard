# NanoClaw Dashboard — environment variables
# Copy to .env and adjust for local development

# Path to NanoClaw central SQLite database
# In production: set via docker-compose.yml environment section
NANOCLAW_DB=/nanoclaw-data/v2.db

# Path to ncl Unix socket
# In production: set via docker-compose.yml environment section
NCL_SOCKET=/ncl.sock

# Server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=production
